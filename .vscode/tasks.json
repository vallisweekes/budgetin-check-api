{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "${env:HOME}/.dotnet/dotnet",
      "args": [
        "build",
        "${workspaceFolder}/BudgetinCheck.sln"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "type": "process",
      "command": "${env:HOME}/.dotnet/dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/BudgetinCheck.Api/BudgetinCheck.Api.csproj",
        "run"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "type": "process",
      "command": "${env:HOME}/.dotnet/dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/src/BudgetinCheck.Api/BudgetinCheck.Api.csproj",
        "-c",
        "Release"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}